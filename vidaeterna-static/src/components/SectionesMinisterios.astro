---
interface Seccion {
  titulo: string;
  bajada: string;
  descripcion: string;
  horario?: string;
  boton: string;
  href: string;
  color: string;
  icono: 'reuniones' | 'biblia' | 'jovenes' | 'ninos' | 'grupos' | 'radio';
}

interface Props {
  secciones?: Seccion[];
  titulo?: string;
  subtitulo?: string;
}

const {
  titulo = 'Nuestros Ministerios',
  subtitulo = 'Encuentra tu lugar en la familia de Vida Eterna',
  secciones = [
    {
      titulo: 'Reuniones Generales',
      bajada: 'Culto y Predicación',
      descripcion:
        'Nos reunimos cada domingo para la Cena del Señor y la predicación de la Palabra. Los viernes, culto de oración y estudio bíblico.',
      horario: 'Dom – 9:00 hs · Vie – 20:00 hs',
      boton: 'Ver horarios',
      href: '/reuniones',
      color: '#1e3a6e',
      icono: 'reuniones',
    },
    {
      titulo: 'Escuela Bíblica Dominical',
      bajada: 'Formación Bíblica',
      descripcion:
        'Clases organizadas por grupos etarios para profundizar en las Escrituras y fomentar el crecimiento espiritual de toda la familia.',
      horario: 'Domingos – luego del culto',
      boton: 'Conocer más',
      href: '/escuela-biblica',
      color: '#1e6b4a',
      icono: 'biblia',
    },
    {
      titulo: 'JUVE',
      bajada: 'Ministerio de Jóvenes',
      descripcion:
        'Jóvenes Unidos Viviendo Esperanza. Un ministerio para formar una generación firme en la fe, arraigada en Cristo, que ora, cuida y comparte el mensaje del Evangelio.',
      horario: 'Sábados – 19:00 hs',
      boton: 'Conocer más',
      href: '/juve',
      color: '#6b2d8b',
      icono: 'jovenes',
    },
    {
      titulo: 'Exploradores',
      bajada: 'Ministerio de Niños',
      descripcion:
        'Un espacio recreativo y formativo para niños de 4 a 12 años, donde la enseñanza bíblica se transmite de manera dinámica y creativa.',
      horario: 'Sáb (c/15 días) – 17:00 a 18:30 hs',
      boton: 'Conocer más',
      href: '/exploradores',
      color: '#c47a1a',
      icono: 'ninos',
    },
    {
      titulo: 'Grupos de Mujeres y Hombres',
      bajada: 'Grupos de Comunión',
      descripcion:
        'Encuentros semanales en hogares para estudiar material bíblico, compartir experiencias y crecer en el discipulado.',
      horario: 'Durante la semana (según grupo)',
      boton: 'Quiero ser parte',
      href: '/grupos',
      color: '#a62c2c',
      icono: 'grupos',
    },
    {
      titulo: 'Radio FM Difusión',
      bajada: 'Ministerio Radial',
      descripcion: '',
      horario: '',
      boton: 'Escuchar',
      href: '/radio',
      color: '#1a5a7a',
      icono: 'radio',
    },
  ],
} = Astro.props;
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-14" data-aos="fade-up">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{titulo}</h2>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">{subtitulo}</p>
    </div>

    <!-- Grid de secciones -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {secciones.map((s, i) => (
        <div
          class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col"
          data-aos="fade-up"
          data-aos-delay={String(i * 80)}
        >
          <!-- Barra de color superior -->
          <div class="h-1.5" style={`background-color: ${s.color}`}></div>

          <div class="p-8 flex flex-col flex-grow">
            <!-- Ícono -->
            <div
              class="w-14 h-14 rounded-xl flex items-center justify-center mb-6"
              style={`background-color: ${s.color}18`}
            >
              {s.icono === 'reuniones' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke={s.color}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21V3m0 0l-4 4m4-4l4 4M3 21h18M5 21V10l7-4 7 4v11" />
                </svg>
              )}
              {s.icono === 'biblia' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke={s.color}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                </svg>
              )}
              {s.icono === 'jovenes' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke={s.color}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                </svg>
              )}
              {s.icono === 'ninos' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke={s.color}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
              )}
              {s.icono === 'grupos' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke={s.color}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              )}
              {s.icono === 'radio' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke={s.color}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 19.5l16.5-15M8.25 19.5h11.25a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H4.5A2.25 2.25 0 002.25 6.75v10.5A2.25 2.25 0 004.5 19.5h.75m0 0v-1.5m0 1.5h.75m10.5-6a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                </svg>
              )}
            </div>

            <!-- Texto -->
            <h3 class="text-xl font-bold text-gray-900 mb-1 leading-snug">
              {s.titulo}
            </h3>
            <p
              class="text-sm font-semibold uppercase tracking-widest mb-4"
              style={`color: ${s.color}`}
            >
              {s.bajada}
            </p>

            {s.descripcion && (
              <p class="text-gray-600 text-sm leading-relaxed mb-4">
                {s.descripcion}
              </p>
            )}

            {s.horario && (
              <div class="flex items-center gap-1.5 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke={s.color}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
                </svg>
                <span class="text-xs font-medium text-gray-500">{s.horario}</span>
              </div>
            )}

            <!-- Botón al fondo de la tarjeta -->
            <div class="mt-auto">
              <a
                href={s.href}
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-white text-sm font-semibold transition-opacity duration-200 hover:opacity-85"
                style={`background-color: ${s.color}`}
              >
                {s.boton}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
