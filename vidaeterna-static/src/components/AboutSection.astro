---
interface Image {
  src: string;
  alt: string;
}

interface Props {
  label?: string;
  title?: string;
  titleHighlight?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  images?: Image[];
}

const {
  label = 'QUIÉNES SOMOS',
  title = 'VIDA ETERNA',
  titleHighlight = 'EN CRISTO',
  description = 'Somos una iglesia dedicada a la predicación del Evangelio, la enseñanza bíblica y la formación de discípulos.',
  ctaText = 'Conocer más',
  ctaHref = '/about',
  images = [],
} = Astro.props;

const hasImages = images.length > 0;
---

<section id="intro" class="py-20 bg-white" data-aos="fade-up" data-aos-duration="1000">
  <div class="container mx-auto px-4">
    <div class={`gap-12 items-center ${hasImages ? 'grid md:grid-cols-2' : 'max-w-3xl mx-auto text-center'}`}>

      <!-- Images (solo si existen) -->
      {hasImages && (
        <div class="relative pb-12">
          <img
            src={images[0].src}
            alt={images[0].alt}
            class="rounded-lg shadow-lg w-full h-[400px] object-cover"
          />
          {images[1] && (
            <img
              src={images[1].src}
              alt={images[1].alt}
              class="rounded-lg shadow-lg w-2/3 h-[300px] object-cover absolute -bottom-8 -right-4 hidden md:block"
            />
          )}
        </div>
      )}

      <!-- Text -->
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest mb-4" style="color: #10375B">{label}</p>
        <h2 class="text-4xl md:text-5xl font-bold mb-6" style="color: #10375B">
          {title} <span style="color: #c47a1a">{titleHighlight}</span>
        </h2>
        <p class="text-gray-600 mb-8 leading-relaxed text-lg">
          {description}
        </p>
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-white font-semibold transition-opacity hover:opacity-85"
          style="background-color: #10375B"
        >
          {ctaText}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
