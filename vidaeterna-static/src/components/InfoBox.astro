---
/**
 * InfoBox — caja de información con borde azul a la izquierda.
 * El contenido se pasa vía <slot />.
 */

interface Props {
  title?: string;
  class?: string;
}

const { title, class: extraClass } = Astro.props;
---

<div class:list={['info-box', extraClass]}>
  {title && <h3 class="text-2xl font-bold mb-4 text-gray-900">{title}</h3>}
  <slot />
</div>
