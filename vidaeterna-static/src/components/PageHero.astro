---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage?: string;
  showCurve?: boolean;
  backgroundColor?: string;
}

const {
  title,
  subtitle,
  backgroundImage,
  showCurve = true,
  backgroundColor = 'bg-blue-900'
} = Astro.props;
---

<section class={`relative py-24 text-white overflow-hidden ${backgroundImage ? '' : backgroundColor}`}>
  {backgroundImage && (
    <div class="absolute inset-0 z-0">
      <img src={backgroundImage} alt={title} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/40"></div>
    </div>
  )}

  <div class="relative z-10 container mx-auto px-4 text-center py-16">
    <h1
      class="text-5xl md:text-6xl font-bold mb-6"
      data-aos="fade-down"
      data-aos-duration="1000"
    >
      {title}
    </h1>
    {subtitle && (
      <p
        class="text-xl md:text-2xl max-w-3xl mx-auto"
        data-aos="fade-up"
        data-aos-delay="200"
      >
        {subtitle}
      </p>
    )}
  </div>

  {showCurve && (
    <div class="absolute bottom-0 left-0 right-0 z-10">
      <svg viewBox="0 0 1440 120" class="w-full h-auto fill-white" preserveAspectRatio="none">
        <path d="M0,0 Q720,120 1440,0 L1440,120 L0,120 Z"></path>
      </svg>
    </div>
  )}
</section>
