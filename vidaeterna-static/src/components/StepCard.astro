---
/**
 * StepCard — tarjeta numerada para procesos paso a paso.
 * Usado en next-steps.astro y similares.
 *
 * linkStyle:
 *   'button' (default) → botón azul sólido
 *   'text'             → enlace de texto azul subrayado
 */

interface Props {
  number: number | string;
  title: string;
  description: string;
  linkText?: string;
  linkHref?: string;
  linkStyle?: 'button' | 'text';
  quote?: string;
  quoteSource?: string;
}

const {
  number,
  title,
  description,
  linkText,
  linkHref = '#',
  linkStyle = 'button',
  quote,
  quoteSource,
} = Astro.props;
---

<div class="flex gap-6">
  <div class="flex-shrink-0">
    <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
      {number}
    </div>
  </div>
  <div class="flex-1">
    <div class="info-box">
      <h3 class="text-2xl font-bold mb-4 text-gray-900">{title}</h3>
      <p class="text-gray-600 mb-4">{description}</p>
      {quote && (
        <p class="text-gray-700 italic mb-4 text-sm">{quote}</p>
      )}
      {quoteSource && (
        <p class="text-gray-500 text-sm mb-4">— {quoteSource}</p>
      )}
      {linkText && (
        linkStyle === 'text' ? (
          <a href={linkHref} class="text-blue-600 font-semibold hover:underline">
            {linkText} →
          </a>
        ) : (
          <a href={linkHref} class="btn-primary-sm">
            {linkText}
          </a>
        )
      )}
    </div>
  </div>
</div>
