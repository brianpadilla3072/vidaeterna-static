---
---

<header class="sticky top-0 z-50 bg-white shadow-md">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between py-4">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-blue-900">
          EPIC CHURCH
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden header:flex items-center space-x-6">
        <a href="/im-new" class="hover:text-blue-600 transition-colors">I'm New</a>
        <a href="/about" class="hover:text-blue-600 transition-colors">About</a>

        <div class="relative group">
          <button class="flex items-center hover:text-blue-600 transition-colors">
            Ministries
            <!-- ChevronDown Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-48 bg-white shadow-lg rounded-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            <a href="/ministries" class="block px-4 py-2 hover:bg-gray-100 font-semibold">All Ministries</a>
            <div class="border-t border-gray-200"></div>
            <a href="/epic-youth" class="block px-4 py-2 hover:bg-gray-100">Epic Youth</a>
            <a href="/epic-kidz" class="block px-4 py-2 hover:bg-gray-100">Epic Kidz</a>
            <a href="/epic-espanol" class="block px-4 py-2 hover:bg-gray-100">Epic Español</a>
          </div>
        </div>

        <a href="/life-groups" class="hover:text-blue-600 transition-colors">Epic Life Groups</a>
        <a href="/sermons" class="hover:text-blue-600 transition-colors">Sermons</a>

        <div class="relative group">
          <button class="flex items-center hover:text-blue-600 transition-colors">
            MORE
            <!-- ChevronDown Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="absolute left-0 mt-2 w-48 bg-white shadow-lg rounded-md opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            <a href="/give" class="block px-4 py-2 hover:bg-gray-100">Give</a>
            <a href="/volunteer" class="block px-4 py-2 hover:bg-gray-100">Volunteer</a>
            <a href="/baptism" class="block px-4 py-2 hover:bg-gray-100">Water Baptism</a>
            <a href="/dedication" class="block px-4 py-2 hover:bg-gray-100">Baby Dedication</a>
          </div>
        </div>

        <a href="/watch-live" class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors">
          Watch Live
        </a>
        <a href="/contact" class="bg-gray-800 text-white px-6 py-2 rounded-md hover:bg-gray-900 transition-colors">
          Contact Us
        </a>
      </nav>

      <!-- Mobile menu toggle -->
      <div class="flex items-center gap-4 header:hidden">
        <button
          id="search-toggle"
          class="p-2"
          aria-label="Toggle search"
        >
          <!-- Search Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
        <button
          id="mobile-menu-toggle"
          class="p-2"
          aria-label="Toggle mobile menu"
        >
          <!-- Menu Icon -->
          <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <line x1="4" y1="6" x2="20" y2="6"></line>
            <line x1="4" y1="18" x2="20" y2="18"></line>
          </svg>
          <!-- X Icon -->
          <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <!-- Search Bar -->
    <div id="search-bar" class="hidden pb-4">
      <input
        type="search"
        placeholder="Search..."
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
    </div>

    <!-- Mobile Menu -->
    <nav id="mobile-menu" class="hidden header:hidden py-4 border-t border-gray-200">
      <a href="/im-new" class="block py-2 hover:text-blue-600">I'm New</a>
      <a href="/about" class="block py-2 hover:text-blue-600">About</a>
      <a href="/ministries" class="block py-2 hover:text-blue-600 font-semibold">Ministries</a>
      <a href="/epic-youth" class="block py-2 pl-4 hover:text-blue-600">Epic Youth</a>
      <a href="/epic-kidz" class="block py-2 pl-4 hover:text-blue-600">Epic Kidz</a>
      <a href="/epic-espanol" class="block py-2 pl-4 hover:text-blue-600">Epic Español</a>
      <a href="/life-groups" class="block py-2 hover:text-blue-600">Epic Life Groups</a>
      <a href="/sermons" class="block py-2 hover:text-blue-600">Sermons</a>
      <a href="/give" class="block py-2 pl-4 hover:text-blue-600">Give</a>
      <a href="/volunteer" class="block py-2 pl-4 hover:text-blue-600">Volunteer</a>
      <a href="/baptism" class="block py-2 pl-4 hover:text-blue-600">Water Baptism</a>
      <a href="/watch-live" class="mt-4 block w-full bg-blue-600 text-center text-white px-6 py-2 rounded-md hover:bg-blue-700">
        Watch Live
      </a>
      <a href="/contact" class="mt-2 block w-full bg-gray-800 text-center text-white px-6 py-2 rounded-md hover:bg-gray-900">
        Contact Us
      </a>
    </nav>
  </div>
</header>

<style>
  /* Transiciones suaves para dropdowns */
  .group .absolute {
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    transform: translateY(-10px);
  }

  .group:hover .absolute {
    transform: translateY(0);
  }

  /* Animación de entrada para items del dropdown */
  .group .absolute a {
    transition: background-color 0.2s ease;
  }

  /* Transición para mobile menu */
  #mobile-menu {
    transition: all 0.3s ease-in-out;
    max-height: 0;
    overflow: hidden;
  }

  #mobile-menu:not(.hidden) {
    max-height: 1000px;
  }

  /* Transición para search bar */
  #search-bar {
    transition: all 0.3s ease-in-out;
    max-height: 0;
    overflow: hidden;
  }

  #search-bar:not(.hidden) {
    max-height: 100px;
  }
</style>

<script>
  // Mobile menu toggle
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  mobileMenuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Search toggle
  const searchToggle = document.getElementById('search-toggle');
  const searchBar = document.getElementById('search-bar');

  searchToggle?.addEventListener('click', () => {
    searchBar?.classList.toggle('hidden');
  });
</script>
