---
---

<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div class="order-2 md:order-1">
        <h2 class="text-4xl md:text-5xl mb-6">
          PLAN YOUR VISIT
        </h2>
        <p class="text-gray-600 mb-8 leading-relaxed">
          Join us for a transformative worship experience. Whether you're looking for
          a church home or just exploring, we'd love to welcome you to our community.
          Come as you are and experience the love of Christ with us.
        </p>

        <div class="grid sm:grid-cols-2 gap-8">
          <!-- Service Times -->
          <div>
            <h4 class="text-xl mb-3">SERVICE TIMES</h4>
            <p class="text-gray-600">
              <strong>Sunday</strong> - 9am & 11am
              <br />
              (2pm online only)
            </p>
          </div>

          <!-- Address -->
          <div>
            <h4 class="text-xl mb-3">ADDRESS</h4>
            <p class="text-gray-600">
              123 Main Street,
              <br />
              Your City, ST 12345
              <br />
              <a href="tel:(555) 123-4567" class="text-blue-600 hover:underline">
                (555) 123-4567
              </a>
            </p>
          </div>
        </div>
      </div>

      <!-- Images -->
      <div class="relative order-1 md:order-2">
        <img
          src="https://images.unsplash.com/photo-1765309541707-4b2bf887e1ca?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxtb2Rlcm4lMjBjaHVyY2glMjBidWlsZGluZyUyMGV4dGVyaW9yfGVufDF8fHx8MTc3MDMwNDg3NHww&ixlib=rb-4.1.0&q=80&w=1080"
          alt="Church building"
          class="rounded-lg shadow-lg w-full h-[400px] object-cover"
        />
        <img
          src="https://images.unsplash.com/photo-1760367121608-79219f1c9d2a?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxkaXZlcnNlJTIwcGVvcGxlJTIwcHJheWluZyUyMHRvZ2V0aGVyfGVufDF8fHx8MTc3MDIzNTQ0Nnww&ixlib=rb-4.1.0&q=80&w=1080"
          alt="Community gathering"
          class="rounded-lg shadow-lg w-2/3 h-[300px] object-cover absolute -bottom-8 -left-4 hidden md:block"
        />
      </div>
    </div>
  </div>
</section>
