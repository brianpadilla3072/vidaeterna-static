---
interface Image {
  src: string;
  alt: string;
}

interface Props {
  title?: string;
  description?: string;
  serviceTimesLabel?: string;
  serviceTimesLines?: string[];
  addressLabel?: string;
  addressLines?: string[];
  phone?: string;
  images?: Image[];
}

const {
  title = 'PLAN YOUR VISIT',
  description = 'EPIC is more than just our name; we believe that Everyone is Precious In Christ, Everyone is Powerful In Christ, and Everyone has Purpose In Christ. that\'s what God has done and is doing, in us and through us. Join us at a service!',
  serviceTimesLabel = 'SERVICE TIMES',
  serviceTimesLines = ['Sunday - 9am & 11am', '(2pm online only)'],
  addressLabel = 'ADDRESS',
  addressLines = ['2707 Main St Extension,', 'Sayreville, NJ 08872'],
  phone = '(732) 727-9500',
  images = [
    {
      src: 'https://www.epicchurchintl.org/images/r/273156776_5477393342290536_2525738704934073148_n/460xg36-0-1744-1114/273156776_5477393342290536_2525738704934073148_n.jpg',
      alt: 'Church building',
    },
    {
      src: 'https://www.epicchurchintl.org/images/r/dsc01554/460xg582-0-4356-2460/dsc01554.jpg',
      alt: 'Community gathering',
    },
  ],
} = Astro.props;
---

<section id="planned-visit" class="py-20 bg-gray-50" data-aos="fade-up" data-aos-duration="1000">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div class="order-2 md:order-1">
        <h2 class="text-4xl md:text-5xl mb-6">
          {title}
        </h2>
        <p class="text-gray-600 mb-8 leading-relaxed">
          {description}
        </p>

        <div class="grid sm:grid-cols-2 gap-8">
          <!-- Service Times -->
          <div>
            <h4 class="text-xl mb-3">{serviceTimesLabel}</h4>
            <p class="text-gray-600">
              {serviceTimesLines.map((line, i) => (
                <>
                  {i > 0 && <br />}
                  {line}
                </>
              ))}
            </p>
          </div>

          <!-- Address -->
          <div>
            <h4 class="text-xl mb-3">{addressLabel}</h4>
            <p class="text-gray-600">
              {addressLines.map((line, i) => (
                <>
                  {i > 0 && <br />}
                  {line}
                </>
              ))}
              {phone && (
                <>
                  <br />
                  <a href={`tel:${phone}`} class="text-blue-600 hover:underline">
                    {phone}
                  </a>
                </>
              )}
            </p>
          </div>
        </div>
      </div>

      <!-- Images -->
      <div class="relative order-1 md:order-2 pb-12">
        <img
          src={images[0].src}
          alt={images[0].alt}
          class="rounded-lg shadow-lg w-full h-[400px] object-cover"
        />
        {images[1] && (
          <img
            src={images[1].src}
            alt={images[1].alt}
            class="rounded-lg shadow-lg w-2/3 h-[300px] object-cover absolute -bottom-8 -left-4 hidden md:block"
          />
        )}
      </div>
    </div>
  </div>
</section>
