---
interface Props {
  name: string;
  description: string;
  image: string;
  link: string;
}

const { name, description, image, link } = Astro.props;
---

<a
  href={link}
  class="block bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-all transform hover:-translate-y-1"
  data-aos="fade-up"
  data-aos-duration="600"
>
  <img src={image} alt={name} class="w-full h-48 object-cover" />
  <div class="p-6">
    <h3 class="text-2xl font-bold mb-3 text-gray-900">{name}</h3>
    <p class="text-gray-600 mb-4">{description}</p>
    <span class="text-blue-600 font-semibold hover:underline">Learn More →</span>
  </div>
</a>
