---
const events = [
  {
    title: 'Youth Night',
    date: 'February 15, 2026',
    time: '7:00 PM',
    location: 'Youth Center',
    image: 'https://images.unsplash.com/photo-1557240503-5ef8ff7a34c3?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHx5b3V0aCUyMGdyb3VwJTIwdGVlbmFnZXJzJTIwY2h1cmNofGVufDF8fHx8MTc3MDI5NDk3OHww&ixlib=rb-4.1.0&q=80&w=1080'
  },
  {
    title: 'Community Outreach',
    date: 'February 22, 2026',
    time: '10:00 AM',
    location: 'Main Campus',
    image: 'https://images.unsplash.com/photo-1760367121608-79219f1c9d2a?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxkaXZlcnNlJTIwcGVvcGxlJTIwcHJheWluZyUyMHRvZ2V0aGVyfGVufDF8fHx8MTc3MDIzNTQ0Nnww&ixlib=rb-4.1.0&q=80&w=1080'
  },
  {
    title: 'Family Fun Day',
    date: 'March 1, 2026',
    time: '12:00 PM',
    location: 'Church Grounds',
    image: 'https://images.unsplash.com/photo-1533656218217-315d259a8d70?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjaGlsZHJlbiUyMGtpZHMlMjBwbGF5aW5nJTIwY2h1cmNofGVufDF8fHx8MTc3MDMwNDg3NHww&ixlib=rb-4.1.0&q=80&w=1080'
  }
];
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-4xl md:text-5xl text-center mb-4">
      UPCOMING EVENTS
    </h2>
    <div class="text-center mb-12">
      <a href="#events" class="text-blue-600 hover:text-blue-700 underline">
        VIEW ALL EVENTS
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {events.map((event) => (
        <div class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
          <img
            src={event.image}
            alt={event.title}
            class="w-full h-48 object-cover"
          />
          <div class="p-6">
            <h3 class="text-2xl mb-3">{event.title}</h3>
            <div class="flex items-start gap-2 text-gray-600 mb-2">
              <!-- Calendar Icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <div>
                <div>{event.date}</div>
                <div class="text-sm">{event.time}</div>
              </div>
            </div>
            <div class="flex items-center gap-2 text-gray-600 mb-4">
              <!-- MapPin Icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span>{event.location}</span>
            </div>
            <a
              href="#event-detail"
              class="inline-block bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 transition-colors"
            >
              Learn More
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
