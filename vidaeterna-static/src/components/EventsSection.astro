---
interface Event {
  title: string;
  date: string;
  link: string;
  image?: string;
}

interface Props {
  title?: string;
  viewAllHref?: string;
  events?: Event[];
  emptyMessage?: string;
}

const {
  title = 'UPCOMING EVENTS',
  viewAllHref = '/events',
  events = [],
  emptyMessage = 'No events were found.',
} = Astro.props;
---

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-4xl md:text-5xl text-center mb-4">
      {title}
    </h2>
    <div class="text-center mb-12">
      <a href={viewAllHref} class="text-blue-600 hover:text-blue-700 underline">
        VIEW ALL EVENTS
      </a>
    </div>

    {events.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {events.map((event) => (
          <a href={event.link} class="block rounded-lg overflow-hidden shadow hover:shadow-md transition-shadow">
            {event.image && (
              <img src={event.image} alt={event.title} class="w-full h-48 object-cover" />
            )}
            <div class="p-4">
              <h3 class="font-semibold text-lg mb-1">{event.title}</h3>
              <p class="text-sm text-gray-500">{event.date}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="message info text-center text-gray-600 py-8">
        {emptyMessage}
      </div>
    )}
  </div>
</section>
