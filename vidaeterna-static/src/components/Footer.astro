---
---

<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-4 py-12">
    <div class="grid md:grid-cols-4 gap-8">
      <!-- Logo Column -->
      <div>
        <div class="text-2xl font-bold mb-4">EPIC CHURCH</div>
        <img
          src="https://via.placeholder.com/150x50/1e3a8a/ffffff?text=EPIC+CHURCH"
          alt="Epic Church Logo"
          class="h-12 w-auto"
        />
      </div>

      <!-- Connect Column -->
      <div>
        <h3 class="text-xl mb-4">Connect With Us</h3>
        <p class="text-gray-400 mb-4 text-sm leading-relaxed">
          A non-denominational, Bible-teaching, Christ-centered church
          dedicated to transforming lives through the power of faith.
        </p>
        <div class="space-y-2 text-sm text-gray-400">
          <div class="flex items-start gap-2">
            <!-- MapPin Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 flex-shrink-0">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>123 Main Street, Your City, ST 12345</span>
          </div>
          <div class="flex items-center gap-2">
            <!-- Phone Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <a href="tel:555-123-4567" class="hover:text-white">
              (555) 123-4567
            </a>
          </div>
        </div>
        <div class="flex gap-4 mt-4">
          <a
            href="https://facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-blue-400 transition-colors"
            aria-label="Facebook"
          >
            <!-- Facebook Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a
            href="https://twitter.com"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-blue-400 transition-colors"
            aria-label="Twitter"
          >
            <!-- Twitter Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
            </svg>
          </a>
          <a
            href="https://instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-pink-400 transition-colors"
            aria-label="Instagram"
          >
            <!-- Instagram Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        </div>
      </div>

      <!-- Service Times Column -->
      <div>
        <h3 class="text-xl mb-4">Sunday Services</h3>
        <div class="text-gray-400 text-sm">
          <p class="mb-2">
            <strong class="text-white">Sunday</strong> - 9am & 11am
          </p>
          <p>(2pm online only)</p>
        </div>
      </div>

      <!-- Menu Column -->
      <div>
        <h3 class="text-xl mb-4">Menu</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/im-new" class="text-gray-400 hover:text-white transition-colors">
              I'm New
            </a>
          </li>
          <li>
            <a href="/about" class="text-gray-400 hover:text-white transition-colors">
              About Us
            </a>
          </li>
          <li>
            <a href="/ministries" class="text-gray-400 hover:text-white transition-colors">
              Ministries
            </a>
          </li>
          <li>
            <a href="/sermons" class="text-gray-400 hover:text-white transition-colors">
              Sermons
            </a>
          </li>
          <li>
            <a href="/give" class="text-gray-400 hover:text-white transition-colors">
              Give
            </a>
          </li>
          <li>
            <a href="/contact" class="text-gray-400 hover:text-white transition-colors">
              Contact
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-gray-800">
    <div class="container mx-auto px-4 py-4">
      <div class="flex flex-col sm:flex-row justify-between items-center text-sm text-gray-400 gap-2">
        <div>© 2026 Epic Church · All Rights Reserved</div>
        <div>Powered by <a href="https://theagroup.com" class="hover:text-white transition-colors">The A Group</a></div>
      </div>
    </div>
  </div>
</footer>
