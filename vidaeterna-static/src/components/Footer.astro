---
type SocialPlatform = 'facebook' | 'twitter' | 'instagram' | 'youtube';

interface SocialLink {
  platform: SocialPlatform | string;
  href: string;
}

interface MenuItem {
  text: string;
  href: string;
}

interface Props {
  churchName?: string;
  logoSrc?: string;
  logoAlt?: string;
  tagline?: string;
  address?: string;
  phone?: string;
  socialLinks?: SocialLink[];
  serviceTimesLabel?: string;
  serviceTimesLines?: string[];
  menuItems?: MenuItem[];
  copyright?: string;
  poweredByText?: string;
  poweredByHref?: string;
}

const {
  churchName = 'EPIC CHURCH',
  logoSrc = 'https://via.placeholder.com/150x50/1e3a8a/ffffff?text=EPIC+CHURCH',
  logoAlt = 'Epic Church Logo',
  tagline = 'A non-denominational, Bible-teaching, Christ-centered church dedicated to transforming lives through the power of faith.',
  address = '123 Main Street, Your City, ST 12345',
  phone = '(555) 123-4567',
  socialLinks = [
    { platform: 'facebook', href: 'https://facebook.com' },
    { platform: 'twitter', href: 'https://twitter.com' },
    { platform: 'instagram', href: 'https://instagram.com' },
  ],
  serviceTimesLabel = 'Sunday Services',
  serviceTimesLines = ['Sunday - 9am & 11am', '(2pm online only)'],
  menuItems = [
    { text: "I'm New", href: '/im-new' },
    { text: 'About Us', href: '/about' },
    { text: 'Ministries', href: '/ministries' },
    { text: 'Sermons', href: '/sermons' },
    { text: 'Give', href: '/give' },
    { text: 'Contact', href: '/contact' },
  ],
  copyright = `© ${new Date().getFullYear()} Epic Church · All Rights Reserved`,
  poweredByText = 'The A Group',
  poweredByHref = 'https://theagroup.com',
} = Astro.props;
---

<footer class="bg-gray-900 text-white">
  <div class="container mx-auto px-4 py-12">
    <div class="grid md:grid-cols-4 gap-8">
      <!-- Logo Column -->
      <div>
        <div class="text-2xl font-bold mb-4">{churchName}</div>
        <img src={logoSrc} alt={logoAlt} class="h-12 w-auto" />
      </div>

      <!-- Connect Column -->
      <div>
        <h3 class="text-xl mb-4">Connect With Us</h3>
        <p class="text-gray-400 mb-4 text-sm leading-relaxed">
          {tagline}
        </p>
        <div class="space-y-2 text-sm text-gray-400">
          <div class="flex items-start gap-2">
            <!-- MapPin Icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 flex-shrink-0">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>{address}</span>
          </div>
          {phone && (
            <div class="flex items-center gap-2">
              <!-- Phone Icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
              <a href={`tel:${phone}`} class="hover:text-white">{phone}</a>
            </div>
          )}
        </div>
        <div class="flex gap-4 mt-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`transition-colors ${social.platform === 'instagram' ? 'hover:text-pink-400' : 'hover:text-blue-400'}`}
              aria-label={social.platform}
            >
              {social.platform === 'facebook' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                </svg>
              )}
              {social.platform === 'twitter' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
                </svg>
              )}
              {social.platform === 'instagram' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
              )}
              {social.platform === 'youtube' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"></path>
                  <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon>
                </svg>
              )}
              {!['facebook','twitter','instagram','youtube'].includes(social.platform) && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                  <polyline points="15 3 21 3 21 9"></polyline>
                  <line x1="10" y1="14" x2="21" y2="3"></line>
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Service Times Column -->
      <div>
        <h3 class="text-xl mb-4">{serviceTimesLabel}</h3>
        <div class="text-gray-400 text-sm">
          {serviceTimesLines.map((line, i) => (
            <p class={i === 0 ? 'mb-2' : ''}>
              {i === 0
                ? <><strong class="text-white">{line.split(' - ')[0]}</strong>{line.includes(' - ') ? ` - ${line.split(' - ')[1]}` : ''}</>
                : line
              }
            </p>
          ))}
        </div>
      </div>

      <!-- Menu Column -->
      <div>
        <h3 class="text-xl mb-4">Menu</h3>
        <ul class="space-y-2 text-sm">
          {menuItems.map((item) => (
            <li>
              <a href={item.href} class="text-gray-400 hover:text-white transition-colors">
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-gray-800">
    <div class="container mx-auto px-4 py-4">
      <div class="flex flex-col sm:flex-row justify-between items-center text-sm text-gray-400 gap-2">
        <div>{copyright}</div>
        {poweredByText && (
          <div>
            Powered by{' '}
            <a href={poweredByHref} class="hover:text-white transition-colors">{poweredByText}</a>
          </div>
        )}
      </div>
    </div>
  </div>
</footer>
