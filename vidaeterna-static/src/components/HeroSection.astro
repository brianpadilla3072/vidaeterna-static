---
interface Button {
  text: string;
  href: string;
  variant?: 'primary' | 'outline';
}

interface Props {
  title?: string;
  videoSrc?: string;
  audioSrc?: string;
  buttons?: Button[];
}

const {
  title = 'BIENVENIDOS',
  videoSrc = '',
  audioSrc = '',
  buttons = [
    { text: 'Ver horarios', href: '/reuniones', variant: 'primary' },
    { text: 'Contáctanos', href: '/contacto', variant: 'outline' },
  ],
} = Astro.props;
---

<section id="hero" class="hero-with-gradient relative text-white overflow-hidden" style="height: 100vh; min-height: 676px; background-color: #10375B;">

  <!-- Video Background (solo si hay videoSrc) -->
  {videoSrc && (
    <video
      class="absolute inset-0 w-full h-full object-cover z-0"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>
  )}

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4">
    <h1 class="text-5xl md:text-7xl font-bold mb-8">
      {title}
    </h1>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      {buttons.map((btn) => (
        <a
          href={btn.href}
          class={
            btn.variant === 'outline'
              ? 'bg-transparent border-2 border-white text-white px-8 py-3 rounded-md hover:bg-white hover:text-blue-900 transition-colors text-lg font-semibold'
              : 'bg-blue-600 text-white px-8 py-3 rounded-md hover:bg-blue-700 transition-colors text-lg font-semibold'
          }
        >
          {btn.text}
        </a>
      ))}
    </div>
  </div>

  <!-- Curve at bottom -->
  <img class="curve curve-bottom absolute bottom-0 left-0 w-full z-10" src="/images/main/curve-white.svg" alt="" />

</section>

<!-- Audio toggle — solo si hay audioSrc -->
{audioSrc && <div id="audio-player-bar" style="position: fixed; top: 80px; right: 20px; z-index: 200; opacity: 0; pointer-events: none; transition: opacity 0.3s ease;">
  <audio id="homepage-audio" loop muted preload="auto">
    <source src={audioSrc} type="audio/mpeg" />
  </audio>
  <button
    id="audio-toggle-btn"
    class="muted"
    aria-label="Toggle Audio"
    style="
      background: rgba(16,55,91,0.85);
      border: 2px solid white;
      color: white;
      border-radius: 50%;
      width: 48px;
      height: 48px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    "
  >🔇</button>
</div>}


<script>
  const audio = document.getElementById('homepage-audio') as HTMLAudioElement;
  const btn = document.getElementById('audio-toggle-btn') as HTMLButtonElement;
  const bar = document.getElementById('audio-player-bar') as HTMLElement | null;
  const hero = document.getElementById('hero');

  // Position the bar just below the actual header height
  const header = document.getElementById('site-header');
  if (header && bar) {
    const updateTop = () => {
      bar.style.top = (header.offsetHeight + 8) + 'px';
    };
    updateTop();
    window.addEventListener('resize', updateTop);
  }

  // Show only while the hero section is visible
  if (hero && bar) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          bar.style.opacity = entry.isIntersecting ? '1' : '0';
          bar.style.pointerEvents = entry.isIntersecting ? 'auto' : 'none';
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(hero);
  }

  // Mute / unmute toggle
  if (audio && btn) {
    btn.addEventListener('click', () => {
      if (audio.muted) {
        audio.muted = false;
        audio.play();
        btn.textContent = '🔊';
        btn.classList.remove('muted');
      } else {
        audio.muted = true;
        btn.textContent = '🔇';
        btn.classList.add('muted');
      }
    });
  }
</script>

<style>
  .hero-with-gradient::before {
    content: "";
    position: absolute;
    z-index: 4;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    display: block;
    background: #10375B;
    background: linear-gradient(180deg, #10375B 0%, rgba(255, 255, 255, 0) 27%);
    pointer-events: none;
  }

  .curve-bottom {
    display: block;
    height: auto;
  }
</style>
