---
const ministries = [
  {
    title: 'Epic Youth',
    image: 'https://images.unsplash.com/photo-1557240503-5ef8ff7a34c3?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHx5b3V0aCUyMGdyb3VwJTIwdGVlbmFnZXJzJTIwY2h1cmNofGVufDF8fHx8MTc3MDI5NDk3OHww&ixlib=rb-4.1.0&q=80&w=1080',
    bgColor: '#141E27',
    link: '#youth'
  },
  {
    title: 'Epic Kidz',
    image: 'https://images.unsplash.com/photo-1533656218217-315d259a8d70?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjaGlsZHJlbiUyMGtpZHMlMjBwbGF5aW5nJTIwY2h1cmNofGVufDF8fHx8MTc3MDMwNDg3NHww&ixlib=rb-4.1.0&q=80&w=1080',
    bgColor: '#0c305d',
    link: '#kids'
  },
  {
    title: 'Grow Your Faith',
    image: 'https://images.unsplash.com/photo-1667068114508-0055f7fb25a3?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w3Nzg4Nzd8MHwxfHNlYXJjaHwxfHxjaHVyY2glMjB3b3JzaGlwJTIwaGFuZHMlMjByYWlzZWR8ZW58MXx8fHwxNzcwMTk4MzgyfDA&ixlib=rb-4.1.0&q=80&w=1080',
    bgColor: '#05203a',
    link: '#ministries'
  }
];
---

<section class="grid md:grid-cols-3">
  {ministries.map((ministry) => (
    <a
      href={ministry.link}
      class="relative h-[400px] overflow-hidden group cursor-pointer"
      style={`background-color: ${ministry.bgColor}`}
    >
      <!-- Background Image with Overlay -->
      <div
        class="absolute inset-0 bg-cover bg-center opacity-20 group-hover:opacity-30 transition-opacity"
        style={`background-image: url(${ministry.image})`}
      ></div>

      <!-- Content -->
      <div class="relative h-full flex flex-col items-center justify-center text-white p-8">
        <h2 class="text-3xl md:text-4xl mb-8 text-center">
          {ministry.title}
        </h2>
        <button class="bg-white text-gray-900 px-6 py-2 rounded-md hover:bg-gray-100 transition-colors">
          LEARN MORE
        </button>
      </div>
    </a>
  ))}
</section>
