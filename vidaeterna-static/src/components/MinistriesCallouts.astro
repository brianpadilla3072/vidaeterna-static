---
interface Ministry {
  title: string;
  image: string;
  bgColor: string;
  link: string;
}

interface Props {
  ministries?: Ministry[];
}

const {
  ministries = [
    {
      title: 'Epic Youth',
      image: 'https://www.epicchurchintl.org/images/r/img_1517/400xg164-766-2953-3207/img_1517.jpg',
      bgColor: '#141E27',
      link: '/ministries/epic-youth',
    },
    {
      title: 'Epic Kidz',
      image: 'https://www.epicchurchintl.org/images/r/0o5a1073/400xg1177-0-5051-3392/0o5a1073.jpg',
      bgColor: '#0c305d',
      link: '/epic-kidz',
    },
    {
      title: 'Grow Your Faith',
      image: 'https://www.epicchurchintl.org/images/r/279458517_5724837127546155_7460128086310909804_n/400xg0-0-1440-1261/279458517_5724837127546155_7460128086310909804_n.jpg',
      bgColor: '#05203a',
      link: '/ministries',
    },
  ],
} = Astro.props;
---

<section class="grid md:grid-cols-3">
  {ministries.map((ministry) => (
    <a
      href={ministry.link}
      class="relative h-[400px] overflow-hidden group cursor-pointer"
      style={`background-color: ${ministry.bgColor}`}
    >
      <!-- Background Image with Overlay -->
      <div
        class="absolute inset-0 bg-cover bg-center opacity-20 group-hover:opacity-30 transition-opacity"
        style={`background-image: url(${ministry.image})`}
      ></div>

      <!-- Content -->
      <div class="relative h-full flex flex-col items-center justify-center text-white p-8">
        <h2 class="text-3xl md:text-4xl mb-8 text-center">
          {ministry.title}
        </h2>
        <button class="bg-white text-gray-900 px-6 py-2 rounded-md hover:bg-gray-100 transition-colors">
          LEARN MORE
        </button>
      </div>
    </a>
  ))}
</section>
