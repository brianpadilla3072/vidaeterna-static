---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import InfoBox from '../components/InfoBox.astro';
import ChecklistItem from '../components/ChecklistItem.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Epic Español - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Epic Español"
        subtitle="¡Bienvenidos a la familia!"
        backgroundImage="https://images.unsplash.com/photo-1511632765486-a01980e01a18?w=1600&h=600&fit=crop"
      />

      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <h2 class="section-title">Nuestro Ministerio</h2>
          <p class="text-gray-600 text-lg leading-relaxed mb-8">
            Epic Español es un ministerio dedicado a alcanzar y servir a la comunidad
            hispana con el amor de Cristo. Creemos que cada persona es preciosa,
            poderosa y tiene un propósito en Cristo.
          </p>

          <InfoBox title="Horarios de Servicio" class="mb-8">
            <p class="text-gray-700 text-lg">
              <strong class="text-blue-600">Domingos</strong> a las 2:00 PM
            </p>
            <p class="text-gray-600 mt-2">Servicios en vivo y en línea disponibles</p>
          </InfoBox>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Lo Que Ofrecemos</h3>
              <ul class="space-y-3 text-gray-600">
                <ChecklistItem text="Enseñanza bíblica en español" />
                <ChecklistItem text="Adoración contemporánea" />
                <ChecklistItem text="Grupos pequeños" />
                <ChecklistItem text="Eventos especiales" />
                <ChecklistItem text="Ministerio de niños" />
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Nuestra Visión</h3>
              <p class="text-gray-600 leading-relaxed">
                Somos una comunidad de fe donde puedes creer, pertenecer y
                convertirte en la mejor versión de ti mismo. Queremos ver vidas
                transformadas por el poder del amor de Dios.
              </p>
            </div>
          </div>
        </div>
      </section>

      <CTASection
        title="¡Te Esperamos!"
        description="Ven y sé parte de esta familia que te ama y te acepta tal como eres."
        buttonText="Contáctanos"
        buttonHref="/contact"
        variant="gradient"
        buttonStyle="secondary"
      />
    </main>

    <Footer />
  </div>
</Layout>
