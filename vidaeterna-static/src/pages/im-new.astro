---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import PlanVisitSection from '../components/PlanVisitSection.astro';
import ChecklistItem from '../components/ChecklistItem.astro';
import InfoBox from '../components/InfoBox.astro';
---

<Layout title="I'm New - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Welcome to EPIC Church"
        subtitle="Coming to a church for the first time should not be a stressful experience."
        backgroundImage="https://images.unsplash.com/photo-1438232992991-995b7058bbb3?w=1600&h=600&fit=crop"
      />

      <!-- Welcome Content -->
      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div data-aos="fade-up">
            <h2 class="section-title">What to Expect</h2>
            <p class="text-gray-600 mb-6 text-lg leading-relaxed">
              We are a community of faith where you can believe, belong, and become
              the best version of yourself. Whether you're exploring faith for the first time
              or looking for a church home, we're here for you.
            </p>
          </div>

          <InfoBox title="Welcome Home Center" class="mb-8" data-aos="fade-up" data-aos-delay="100">
            <p class="text-gray-700 leading-relaxed">
              First time here? Stop at our Welcome Home center to receive a greeting,
              a gift, and answers to any questions you may have. Our team is ready to
              help you feel at home from the moment you arrive.
            </p>
          </InfoBox>

          <div class="grid md:grid-cols-2 gap-8 mb-8">
            <div class="bg-white p-6 rounded-lg border border-gray-200" data-aos="fade-right" data-aos-delay="100">
              <h3 class="text-xl font-bold mb-3 text-gray-900">We Are:</h3>
              <ul class="space-y-2 text-gray-600">
                <ChecklistItem text="Non-denominational" />
                <ChecklistItem text="Bible-teaching" />
                <ChecklistItem text="Spirit-filled" />
                <ChecklistItem text="Christ-centered" />
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200" data-aos="fade-left" data-aos-delay="100">
              <h3 class="text-xl font-bold mb-3 text-gray-900">Service Times:</h3>
              <p class="text-gray-700 mb-2">
                <strong class="text-blue-600">Sunday</strong> - 9am & 11am
              </p>
              <p class="text-gray-600 text-sm">(2pm online only)</p>
              <div class="mt-4 pt-4 border-t border-gray-200">
                <p class="text-gray-700">
                  <strong>Address:</strong><br />
                  123 Main Street<br />
                  Your City, ST 12345
                </p>
              </div>
            </div>
          </div>

          <div class="text-center" data-aos="fade-up" data-aos-delay="200">
            <a href="/contact" class="btn-primary">Get Directions</a>
          </div>
        </div>
      </section>

      <PlanVisitSection />
    </main>

    <Footer />
  </div>
</Layout>
