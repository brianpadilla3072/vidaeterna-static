---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import ChecklistItem from '../components/ChecklistItem.astro';
import InfoBox from '../components/InfoBox.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Epic Youth - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Epic Youth"
        subtitle="Grades 6th - 12th"
        backgroundImage="https://images.unsplash.com/photo-1529070538774-1843cb3265df?w=1600&h=600&fit=crop"
      />

      <!-- Content -->
      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="mb-12">
            <h2 class="section-title">A Place to Belong</h2>
            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              Epic Youth is a safe, fun environment for teens to grow in their faith,
              build lasting friendships, and discover their God-given purpose.
              We're all about helping students navigate life with Jesus at the center.
            </p>
          </div>

          <InfoBox title="When We Meet" class="mb-12">
            <div class="space-y-3">
              <p class="text-gray-700">
                <strong class="text-blue-600">Fridays</strong> at 7:30pm
              </p>
              <p class="text-gray-700">
                <strong class="text-blue-600">Sundays</strong> during 1st and 2nd service (9am and 11am)
              </p>
            </div>
          </InfoBox>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">What We Do</h3>
              <ul class="space-y-3 text-gray-600">
                <ChecklistItem text="Weekly worship and teaching" />
                <ChecklistItem text="Intentional small groups" />
                <ChecklistItem text="Monthly events and outings" />
                <ChecklistItem text="Youth retreats and camps" />
                <ChecklistItem text="Service opportunities" />
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Our Mission</h3>
              <p class="text-gray-600 leading-relaxed">
                To create a space where students can encounter Jesus, build
                authentic community, and discover their unique calling.
                We believe every teen is valuable and has a purpose.
              </p>
            </div>
          </div>

          <!-- Event Promo -->
          <CTASection
            title="Summer Camp 2026"
            description="Join us for an unforgettable week of worship, adventure, and life-change!"
            buttonText="SIGN UP HERE!"
            buttonHref="/contact"
            variant="gradient"
            py="py-8"
          >
            <p class="text-lg mb-6 text-white/90">July 15-20, 2026</p>
          </CTASection>
        </div>
      </section>

      <CTASection
        title="Questions?"
        description="We'd love to connect with you and your teen!"
        buttonText="Contact Youth Team"
        buttonHref="/contact"
        variant="light"
        buttonStyle="primary"
      />
    </main>

    <Footer />
  </div>
</Layout>
