---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Epic Youth - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Epic Youth"
        subtitle="Grades 6th - 12th"
        backgroundImage="https://images.unsplash.com/photo-1529070538774-1843cb3265df?w=1600&h=600&fit=crop"
      />

      <!-- Content -->
      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="mb-12">
            <h2 class="text-4xl font-bold mb-6 text-gray-900">A Place to Belong</h2>
            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              Epic Youth is a safe, fun environment for teens to grow in their faith,
              build lasting friendships, and discover their God-given purpose.
              We're all about helping students navigate life with Jesus at the center.
            </p>
          </div>

          <div class="bg-blue-50 p-8 rounded-lg mb-12 border-l-4 border-blue-600">
            <h3 class="text-2xl font-bold mb-4 text-gray-900">When We Meet</h3>
            <div class="space-y-3">
              <p class="text-gray-700">
                <strong class="text-blue-600">Fridays</strong> at 7:30pm
              </p>
              <p class="text-gray-700">
                <strong class="text-blue-600">Sundays</strong> during 1st and 2nd service (9am and 11am)
              </p>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">What We Do</h3>
              <ul class="space-y-3 text-gray-600">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Weekly worship and teaching
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Intentional small groups
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Monthly events and outings
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Youth retreats and camps
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Service opportunities
                </li>
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Our Mission</h3>
              <p class="text-gray-600 leading-relaxed">
                To create a space where students can encounter Jesus, build
                authentic community, and discover their unique calling.
                We believe every teen is valuable and has a purpose.
              </p>
            </div>
          </div>

          <!-- Event Promo -->
          <div class="bg-gradient-to-r from-blue-900 to-blue-700 text-white rounded-lg overflow-hidden">
            <div class="p-8 text-center">
              <h3 class="text-3xl font-bold mb-4">Summer Camp 2026</h3>
              <p class="text-xl mb-6">
                Join us for an unforgettable week of worship, adventure, and life-change!
              </p>
              <p class="text-lg mb-6">July 15-20, 2026</p>
              <a href="/contact" class="inline-block bg-white text-blue-900 px-8 py-3 rounded-md text-lg font-semibold hover:bg-gray-100 transition-colors">
                SIGN UP HERE!
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="py-16 bg-gray-50">
        <div class="container mx-auto px-4 text-center">
          <h3 class="text-3xl font-bold mb-4 text-gray-900">Questions?</h3>
          <p class="text-xl text-gray-600 mb-6">
            We'd love to connect with you and your teen!
          </p>
          <a href="/contact" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-md text-lg font-semibold hover:bg-blue-700 transition-colors">
            Contact Youth Team
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
