---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import ChecklistItem from '../components/ChecklistItem.astro';
import InfoBox from '../components/InfoBox.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="Epic Kidz - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Epic Kidz"
        subtitle="Where Kids Meet Jesus!"
        backgroundImage="https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=1600&h=600&fit=crop"
      />

      <!-- Content -->
      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="mb-12">
            <h2 class="section-title">A Safe Place to Grow</h2>
            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              Epic Kidz is a fun and safe environment where children can learn about
              God's love through age-appropriate lessons, worship, games, and activities.
              We partner with parents to help kids build a strong foundation of faith.
            </p>
          </div>

          <InfoBox title="Age Groups" class="mb-12">
            <div class="space-y-3">
              <p class="text-gray-700">
                <strong class="text-blue-600">Nursery:</strong> Birth - 2 years
              </p>
              <p class="text-gray-700">
                <strong class="text-blue-600">Preschool:</strong> 3 - 5 years
              </p>
              <p class="text-gray-700">
                <strong class="text-blue-600">Elementary:</strong> Grades K - 5th
              </p>
            </div>
            <div class="mt-6 pt-6 border-t border-blue-200">
              <p class="text-gray-700">
                <strong>Available during:</strong> Sunday 9am & 11am services
              </p>
            </div>
          </InfoBox>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">What We Offer</h3>
              <ul class="space-y-3 text-gray-600">
                <ChecklistItem text="Bible-based curriculum" />
                <ChecklistItem text="Engaging worship and music" />
                <ChecklistItem text="Interactive games and activities" />
                <ChecklistItem text="Small group discussions" />
                <ChecklistItem text="Special events and parties" />
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Safety & Security</h3>
              <p class="text-gray-600 leading-relaxed mb-4">
                Your child's safety is our top priority. All volunteers are
                background-checked and trained.
              </p>
              <ul class="space-y-2 text-gray-600 text-sm">
                <ChecklistItem text="Secure check-in/check-out system" size="sm" />
                <ChecklistItem text="Name tags for identification" size="sm" />
                <ChecklistItem text="Clean, supervised environments" size="sm" />
                <ChecklistItem text="Medical alert system" size="sm" />
              </ul>
            </div>
          </div>

          <!-- Parent Resources -->
          <div class="bg-gradient-to-r from-purple-900 to-purple-700 text-white rounded-lg overflow-hidden">
            <div class="p-8">
              <h3 class="text-3xl font-bold mb-4">For Parents</h3>
              <p class="text-lg mb-6">
                We believe parents are the primary spiritual influence in their
                child's life. That's why we provide resources to help you continue
                the conversation at home.
              </p>
              <div class="grid md:grid-cols-3 gap-4 text-sm">
                <div class="bg-white/10 p-4 rounded">
                  <strong>Weekly Lessons</strong>
                  <p class="mt-2 text-white/90">Download family discussion guides</p>
                </div>
                <div class="bg-white/10 p-4 rounded">
                  <strong>Memory Verses</strong>
                  <p class="mt-2 text-white/90">Practice together at home</p>
                </div>
                <div class="bg-white/10 p-4 rounded">
                  <strong>Activities</strong>
                  <p class="mt-2 text-white/90">Fun ways to reinforce learning</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <CTASection
        title="First Time Visiting?"
        description="We can't wait to meet your family! Have questions? We're here to help."
        buttonText="Contact Kidz Team"
        buttonHref="/contact"
        variant="light"
        buttonStyle="primary"
      />
    </main>

    <Footer />
  </div>
</Layout>
