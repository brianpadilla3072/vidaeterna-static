---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Water Baptism - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Water Baptism"
        subtitle="Take your next step of faith"
        backgroundImage="https://images.unsplash.com/photo-1438032005730-c779502df39b?w=1600&h=600&fit=crop"
      />

      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="mb-12">
            <h2 class="text-4xl font-bold mb-6 text-gray-900">What is Water Baptism?</h2>
            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              Water baptism is an outward expression of an inward commitment to Jesus Christ.
              It's a public declaration of your faith and a powerful step of obedience that
              symbolizes your new life in Christ.
            </p>
            <p class="text-gray-600 leading-relaxed">
              When you are baptized, you are identifying with Jesus in His death, burial,
              and resurrection. It's a beautiful picture of leaving your old life behind
              and rising to walk in newness of life.
            </p>
          </div>

          <div class="bg-blue-50 p-8 rounded-lg mb-12 border-l-4 border-blue-600">
            <h3 class="text-2xl font-bold mb-4 text-gray-900">What the Bible Says</h3>
            <div class="space-y-4">
              <div>
                <p class="text-gray-700 italic mb-2">
                  "Therefore go and make disciples of all nations, baptizing them
                  in the name of the Father and of the Son and of the Holy Spirit."
                </p>
                <p class="text-gray-600 text-sm">- Matthew 28:19</p>
              </div>
              <div>
                <p class="text-gray-700 italic mb-2">
                  "We were therefore buried with him through baptism into death
                  in order that, just as Christ was raised from the dead through
                  the glory of the Father, we too may live a new life."
                </p>
                <p class="text-gray-600 text-sm">- Romans 6:4</p>
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Who Should Be Baptized?</h3>
              <p class="text-gray-600 mb-4">
                Anyone who has made a personal decision to follow Jesus Christ
                and accept Him as their Lord and Savior.
              </p>
              <ul class="space-y-2 text-gray-600 text-sm">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  You believe Jesus died for your sins
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  You have accepted Him as your Savior
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  You want to follow Him publicly
                </li>
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">What to Expect</h3>
              <p class="text-gray-600 mb-4">
                Baptism services are held regularly throughout the year.
              </p>
              <ul class="space-y-2 text-gray-600 text-sm">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Brief meeting before the service
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Share your testimony (optional)
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Baptism by full immersion
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Celebration with church family
                </li>
              </ul>
            </div>
          </div>

          <div class="bg-gradient-to-r from-blue-900 to-blue-700 text-white rounded-lg p-12">
            <h3 class="text-3xl font-bold mb-6 text-center">Sign Up for Baptism</h3>
            <p class="text-xl text-center mb-8 text-white/90">
              Ready to take this important step? Fill out the form below!
            </p>

            <form class="max-w-2xl mx-auto space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold mb-2">First Name *</label>
                  <input
                    type="text"
                    required
                    class="w-full px-4 py-3 rounded-md text-gray-900"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold mb-2">Last Name *</label>
                  <input
                    type="text"
                    required
                    class="w-full px-4 py-3 rounded-md text-gray-900"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Email *</label>
                <input
                  type="email"
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Phone *</label>
                <input
                  type="tel"
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Age Group *</label>
                <select
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                >
                  <option value="">Select...</option>
                  <option value="child">Child (under 12)</option>
                  <option value="teen">Teen (13-17)</option>
                  <option value="adult">Adult (18+)</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">
                  Have you accepted Jesus as your personal Savior? *
                </label>
                <select
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                >
                  <option value="">Select...</option>
                  <option value="yes">Yes</option>
                  <option value="no">Not yet - I'd like to talk to someone</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">
                  Share your testimony (optional)
                </label>
                <textarea
                  rows="4"
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                  placeholder="Tell us about your decision to follow Jesus..."
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full bg-white text-blue-900 px-6 py-3 rounded-md text-lg font-semibold hover:bg-gray-100 transition-colors"
              >
                Submit Registration
              </button>
            </form>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
