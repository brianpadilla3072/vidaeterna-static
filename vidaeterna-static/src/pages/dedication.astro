---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Baby & Family Dedication - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Baby & Family Dedication"
        subtitle="Commit your family to God together"
        backgroundImage="https://images.unsplash.com/photo-1476703993599-0035a21b17a9?w=1600&h=600&fit=crop"
      />

      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="mb-12">
            <h2 class="text-4xl font-bold mb-6 text-gray-900">What is Baby Dedication?</h2>
            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              Baby and family dedication is a special service where parents make
              a public commitment to raise their children according to biblical
              principles and in the ways of the Lord. It's also a time when the
              church family commits to supporting and praying for your family.
            </p>
            <p class="text-gray-600 leading-relaxed">
              This is not infant baptism. Rather, it's an opportunity for parents
              to dedicate themselves to God's calling as parents and to commit to
              raising their children to know and love Jesus.
            </p>
          </div>

          <div class="bg-blue-50 p-8 rounded-lg mb-12 border-l-4 border-blue-600">
            <h3 class="text-2xl font-bold mb-4 text-gray-900">Biblical Foundation</h3>
            <div class="space-y-4">
              <div>
                <p class="text-gray-700 italic mb-2">
                  "Start children off on the way they should go, and even when
                  they are old they will not turn from it."
                </p>
                <p class="text-gray-600 text-sm">- Proverbs 22:6</p>
              </div>
              <div>
                <p class="text-gray-700 italic mb-2">
                  "People were bringing little children to Jesus for him to place
                  his hands on them, but the disciples rebuked them. When Jesus
                  saw this, he was indignant. He said to them, 'Let the little
                  children come to me, and do not hinder them, for the kingdom
                  of God belongs to such as these.'"
                </p>
                <p class="text-gray-600 text-sm">- Mark 10:13-14</p>
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Parent Commitment</h3>
              <p class="text-gray-600 mb-4">
                As parents, you will commit to:
              </p>
              <ul class="space-y-2 text-gray-600 text-sm">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Live as an example of Christ's love
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Teach them God's Word
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Pray for and with your children
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Lead them to a personal relationship with Jesus
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Raise them in a church community
                </li>
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-xl font-bold mb-4 text-gray-900">Church Commitment</h3>
              <p class="text-gray-600 mb-4">
                Our church family commits to:
              </p>
              <ul class="space-y-2 text-gray-600 text-sm">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Pray for your family regularly
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Support you in your parenting journey
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Provide a safe, nurturing environment
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Be positive role models for your children
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Partner with you in their spiritual growth
                </li>
              </ul>
            </div>
          </div>

          <div class="bg-gradient-to-r from-purple-900 to-purple-700 text-white rounded-lg p-12">
            <h3 class="text-3xl font-bold mb-6 text-center">Register for Dedication</h3>
            <p class="text-xl text-center mb-8 text-white/90">
              We'd be honored to celebrate this special moment with you!
            </p>

            <form class="max-w-2xl mx-auto space-y-6">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold mb-2">Parent/Guardian Name *</label>
                  <input
                    type="text"
                    required
                    class="w-full px-4 py-3 rounded-md text-gray-900"
                  />
                </div>
                <div>
                  <label class="block text-sm font-semibold mb-2">Spouse/Co-Parent Name</label>
                  <input
                    type="text"
                    class="w-full px-4 py-3 rounded-md text-gray-900"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Email *</label>
                <input
                  type="email"
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Phone *</label>
                <input
                  type="tel"
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Child's Name *</label>
                <input
                  type="text"
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">Child's Birthdate *</label>
                <input
                  type="date"
                  required
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                />
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">
                  Are you dedicating additional children?
                </label>
                <select
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                >
                  <option value="no">No, just one child</option>
                  <option value="yes">Yes (we'll contact you for details)</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-semibold mb-2">
                  Additional Information or Questions
                </label>
                <textarea
                  rows="4"
                  class="w-full px-4 py-3 rounded-md text-gray-900"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full bg-white text-purple-900 px-6 py-3 rounded-md text-lg font-semibold hover:bg-gray-100 transition-colors"
              >
                Submit Registration
              </button>
            </form>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
