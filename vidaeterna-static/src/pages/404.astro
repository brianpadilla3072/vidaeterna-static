---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found — Epic Church" description="The page you're looking for doesn't exist.">
  <div class="min-h-screen bg-white flex flex-col">
    <Header />

    <main class="flex-1 flex items-center justify-center py-24">
      <div class="text-center px-4 max-w-xl mx-auto">
        <p class="text-8xl font-bold text-blue-600 mb-4">404</p>
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Page Not Found</h1>
        <p class="text-xl text-gray-600 mb-10 leading-relaxed">
          The page you're looking for doesn't exist or may have been moved.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/" class="btn-primary">Go Home</a>
          <a href="/contact" class="btn-secondary">Contact Us</a>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
