---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import IconCard from '../components/IconCard.astro';
import ChecklistItem from '../components/ChecklistItem.astro';
import InfoBox from '../components/InfoBox.astro';
---

<Layout title="Ministry Masterclass - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Ministry Masterclass"
        subtitle="Equipping leaders for excellence"
        backgroundImage="https://images.unsplash.com/photo-1552664730-d307ca884978?w=1600&h=600&fit=crop"
      />

      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="mb-12">
            <h2 class="section-title">Level Up Your Leadership</h2>
            <p class="text-gray-600 text-lg leading-relaxed mb-6">
              Ministry Masterclass is an intensive training program designed to equip
              current and aspiring leaders with the tools, knowledge, and character
              development needed to serve with excellence in ministry.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Whether you're leading in your workplace, church, or community, this
              program will help you grow in your calling and maximize your impact.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-8 mb-12">
            <IconCard title="Biblical Foundation" description="Deep dive into God's Word and leadership principles">
              <svg slot="icon" class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
            </IconCard>

            <IconCard title="Practical Training" description="Real-world skills for effective ministry">
              <svg slot="icon" class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </IconCard>

            <IconCard title="Character Development" description="Growing in integrity and spiritual maturity">
              <svg slot="icon" class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </IconCard>
          </div>

          <div class="bg-gradient-to-r from-blue-900 to-blue-700 text-white rounded-lg p-12 mb-12">
            <h3 class="text-3xl font-bold mb-8 text-center">Course Curriculum</h3>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3">Module 1: Foundations</h4>
                <ul class="space-y-2 text-sm text-white/90">
                  <li>• Biblical leadership principles</li>
                  <li>• Understanding your calling</li>
                  <li>• Character over competence</li>
                  <li>• Servant leadership</li>
                </ul>
              </div>
              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3">Module 2: Vision & Strategy</h4>
                <ul class="space-y-2 text-sm text-white/90">
                  <li>• Developing vision</li>
                  <li>• Strategic planning</li>
                  <li>• Building teams</li>
                  <li>• Executing with excellence</li>
                </ul>
              </div>
              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3">Module 3: Communication</h4>
                <ul class="space-y-2 text-sm text-white/90">
                  <li>• Public speaking</li>
                  <li>• Teaching & preaching</li>
                  <li>• Conflict resolution</li>
                  <li>• Difficult conversations</li>
                </ul>
              </div>
              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3">Module 4: Leadership Skills</h4>
                <ul class="space-y-2 text-sm text-white/90">
                  <li>• Time management</li>
                  <li>• Delegation & empowerment</li>
                  <li>• Financial stewardship</li>
                  <li>• Leading change</li>
                </ul>
              </div>
              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3">Module 5: Spiritual Health</h4>
                <ul class="space-y-2 text-sm text-white/90">
                  <li>• Personal spiritual disciplines</li>
                  <li>• Prayer & fasting</li>
                  <li>• Avoiding burnout</li>
                  <li>• Work-life balance</li>
                </ul>
              </div>
              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3">Module 6: Ministry Practice</h4>
                <ul class="space-y-2 text-sm text-white/90">
                  <li>• Mentoring others</li>
                  <li>• Pastoral care</li>
                  <li>• Evangelism & discipleship</li>
                  <li>• Building community</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-8 mb-12">
            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-2xl font-bold mb-4 text-gray-900">Program Details</h3>
              <ul class="space-y-3 text-gray-600">
                <ChecklistItem text="Duration: 12 weeks" />
                <ChecklistItem text="Schedule: Wednesday evenings 7–9 PM" />
                <ChecklistItem text="Location: Epic Church Main Campus" />
                <ChecklistItem text="Investment: $99 (includes all materials)" />
              </ul>
            </div>

            <div class="bg-white p-6 rounded-lg border border-gray-200">
              <h3 class="text-2xl font-bold mb-4 text-gray-900">Who Should Attend?</h3>
              <ul class="space-y-3 text-gray-600">
                <ChecklistItem text="Current ministry leaders" />
                <ChecklistItem text="Aspiring leaders" />
                <ChecklistItem text="Life group leaders" />
                <ChecklistItem text="Ministry volunteers" />
                <ChecklistItem text="Business professionals" />
                <ChecklistItem text="Anyone sensing a call to leadership" />
              </ul>
            </div>
          </div>

          <div class="text-center mb-12">
            <h3 class="text-3xl font-bold mb-6 text-gray-900">Next Cohort Starts Soon!</h3>
            <p class="section-subtitle mb-8">
              Space is limited to ensure personalized attention. Register today to
              secure your spot in the next Ministry Masterclass.
            </p>
            <a href="/contact" class="btn-primary px-12 py-4 text-xl">Register Now</a>
          </div>

          <InfoBox title="Testimonial">
            <p class="text-gray-700 italic mb-4">
              "Ministry Masterclass transformed my understanding of leadership. The
              practical tools and biblical foundation have equipped me to lead with
              confidence and humility. I can't recommend it enough!"
            </p>
            <p class="text-gray-600 text-sm">- Sarah M., Life Group Leader</p>
          </InfoBox>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
