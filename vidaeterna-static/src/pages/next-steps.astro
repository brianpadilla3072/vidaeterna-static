---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Next Steps - Epic Church">
  <div class="min-h-screen bg-white">
    <Header />

    <main>
      <PageHero
        title="Next Steps"
        subtitle="Your journey of faith starts here"
        backgroundImage="https://images.unsplash.com/photo-1501594907352-04cda38ebc29?w=1600&h=600&fit=crop"
      />

      <section class="py-20 bg-white">
        <div class="container mx-auto px-4 max-w-4xl">
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold mb-6 text-gray-900">Your Spiritual Growth Journey</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
              At Epic Church, we believe that following Jesus is a journey, not a destination.
              We're here to walk with you every step of the way. Here are some practical
              next steps you can take to grow in your faith.
            </p>
          </div>

          <!-- Step-by-Step Process -->
          <div class="space-y-8 mb-16">
            <!-- Step 1 -->
            <div class="flex gap-6">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
                  1
                </div>
              </div>
              <div class="flex-1">
                <div class="bg-blue-50 p-8 rounded-lg border-l-4 border-blue-600">
                  <h3 class="text-2xl font-bold mb-4 text-gray-900">Accept Jesus</h3>
                  <p class="text-gray-600 mb-4">
                    The first and most important step is accepting Jesus Christ as your
                    personal Lord and Savior. This is where your relationship with God begins.
                  </p>
                  <p class="text-gray-700 italic mb-4 text-sm">
                    "If you declare with your mouth, 'Jesus is Lord,' and believe in your
                    heart that God raised him from the dead, you will be saved." - Romans 10:9
                  </p>
                  <a href="/contact" class="text-blue-600 font-semibold hover:underline">
                    Talk to someone about this step →
                  </a>
                </div>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="flex gap-6">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
                  2
                </div>
              </div>
              <div class="flex-1">
                <div class="bg-blue-50 p-8 rounded-lg border-l-4 border-blue-600">
                  <h3 class="text-2xl font-bold mb-4 text-gray-900">Get Baptized</h3>
                  <p class="text-gray-600 mb-4">
                    Baptism is your public declaration of faith in Jesus. It's an outward
                    expression of the inward change that has taken place in your life.
                  </p>
                  <a href="/baptism" class="inline-block bg-blue-600 text-white px-6 py-2 rounded-md font-semibold hover:bg-blue-700 transition-colors">
                    Sign Up for Baptism
                  </a>
                </div>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="flex gap-6">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
                  3
                </div>
              </div>
              <div class="flex-1">
                <div class="bg-blue-50 p-8 rounded-lg border-l-4 border-blue-600">
                  <h3 class="text-2xl font-bold mb-4 text-gray-900">Join a Life Group</h3>
                  <p class="text-gray-600 mb-4">
                    Faith is best lived in community. Life Groups provide a place where you
                    can build meaningful relationships, grow spiritually, and find support.
                  </p>
                  <a href="/life-groups" class="inline-block bg-blue-600 text-white px-6 py-2 rounded-md font-semibold hover:bg-blue-700 transition-colors">
                    Find a Life Group
                  </a>
                </div>
              </div>
            </div>

            <!-- Step 4 -->
            <div class="flex gap-6">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
                  4
                </div>
              </div>
              <div class="flex-1">
                <div class="bg-blue-50 p-8 rounded-lg border-l-4 border-blue-600">
                  <h3 class="text-2xl font-bold mb-4 text-gray-900">Discover Your Purpose</h3>
                  <p class="text-gray-600 mb-4">
                    God has uniquely gifted you to make a difference. Explore how you can
                    use your talents and passions to serve in the church and community.
                  </p>
                  <a href="/volunteer" class="inline-block bg-blue-600 text-white px-6 py-2 rounded-md font-semibold hover:bg-blue-700 transition-colors">
                    Start Serving
                  </a>
                </div>
              </div>
            </div>

            <!-- Step 5 -->
            <div class="flex gap-6">
              <div class="flex-shrink-0">
                <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
                  5
                </div>
              </div>
              <div class="flex-1">
                <div class="bg-blue-50 p-8 rounded-lg border-l-4 border-blue-600">
                  <h3 class="text-2xl font-bold mb-4 text-gray-900">Grow as a Leader</h3>
                  <p class="text-gray-600 mb-4">
                    As you mature in your faith, consider developing your leadership skills
                    through our Ministry Masterclass program or by leading a Life Group.
                  </p>
                  <a href="/ministry-masterclass" class="inline-block bg-blue-600 text-white px-6 py-2 rounded-md font-semibold hover:bg-blue-700 transition-colors">
                    Learn About Leadership Training
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Daily Spiritual Practices -->
          <div class="bg-gradient-to-r from-gray-900 to-gray-700 text-white rounded-lg p-12 mb-12">
            <h3 class="text-3xl font-bold mb-8 text-center">Daily Spiritual Practices</h3>
            <p class="text-center text-white/90 mb-8 max-w-2xl mx-auto">
              In addition to these milestone steps, cultivate these daily habits to grow closer to God:
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3 flex items-center">
                  <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                  </svg>
                  Read the Bible
                </h4>
                <p class="text-white/90 text-sm">
                  Start with just 10 minutes a day. Try reading a chapter from the
                  Gospels or Psalms.
                </p>
              </div>

              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3 flex items-center">
                  <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                  </svg>
                  Pray Daily
                </h4>
                <p class="text-white/90 text-sm">
                  Talk to God throughout your day. Share your joys, concerns,
                  and gratitude with Him.
                </p>
              </div>

              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3 flex items-center">
                  <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                  Connect with Others
                </h4>
                <p class="text-white/90 text-sm">
                  Attend church regularly and build friendships with other believers
                  who can encourage you.
                </p>
              </div>

              <div class="bg-white/10 p-6 rounded-lg">
                <h4 class="text-xl font-bold mb-3 flex items-center">
                  <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                  Serve Others
                </h4>
                <p class="text-white/90 text-sm">
                  Look for opportunities to show God's love through acts of kindness
                  and service.
                </p>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <div class="text-center">
            <h3 class="text-3xl font-bold mb-6 text-gray-900">Questions About Your Next Step?</h3>
            <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
              We're here to help you on your journey. Don't hesitate to reach out!
            </p>
            <a href="/contact" class="inline-block bg-blue-600 text-white px-12 py-4 rounded-md text-xl font-semibold hover:bg-blue-700 transition-colors">
              Talk to Someone
            </a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
