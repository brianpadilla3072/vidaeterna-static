---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import SectionesMinisterios from '../components/SectionesMinisterios.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Iglesia Vida Eterna"
  description="Iglesia Vida Eterna — Una comunidad de fe viva en Jesucristo"
>
  <div class="min-h-screen bg-white">
    <Header
      transparent={true}
      logo={{ src: '/images/main/epic-logo.png', alt: 'Iglesia Vida Eterna', href: '/' }}
      navItems={[
        { text: 'Inicio', href: '/' },
        { text: 'Reuniones', href: '/reuniones' },
        {
          text: 'Ministerios',
          href: '/ministerios',
          children: [
            { text: 'Escuela Bíblica Dominical', href: '/escuela-biblica' },
            { text: 'JUVE – Jóvenes', href: '/juve' },
            { text: 'Exploradores – Niños', href: '/exploradores' },
            { text: 'Grupos de Mujeres y Hombres', href: '/grupos' },
          ],
        },
        { text: 'Contacto', href: '/contacto' },
      ]}
      ctaButton={{ text: 'Radio FM', href: '/radio' }}
      givePaypalId=""
    />
    <main>
      <HeroSection
        title="BIENVENIDOS A VIDA ETERNA"
        buttons={[
          { text: 'Ver horarios', href: '/reuniones', variant: 'primary' },
          { text: 'Contáctanos', href: '/contacto', variant: 'outline' },
        ]}
      />
      <AboutSection
        label="QUIÉNES SOMOS"
        title="VIDA ETERNA"
        titleHighlight="EN CRISTO"
        description="Somos una iglesia dedicada a la predicación del Evangelio, la enseñanza bíblica y la formación de discípulos. Proclamamos que en Jesucristo hay perdón, salvación y vida eterna, y desde hace más de ocho décadas compartimos ese mensaje con nuestra comunidad."
        ctaText="Conocer más"
        ctaHref="/about"
      />
      <SectionesMinisterios
        titulo="Nuestros Ministerios"
        subtitulo="Encuentra tu lugar en la familia de Vida Eterna"
      />
    </main>
    <Footer
      churchName="IGLESIA VIDA ETERNA"
      logoSrc="/images/main/epic-logo.png"
      logoAlt="Iglesia Vida Eterna"
      tagline="Una comunidad de fe viva, centrada en Cristo y comprometida con la Palabra de Dios."
      address=""
      phone=""
      socialLinks={[
        { platform: 'facebook', href: 'https://facebook.com' },
        { platform: 'instagram', href: 'https://instagram.com' },
        { platform: 'youtube', href: 'https://youtube.com' },
      ]}
      serviceTimesLabel="Reuniones"
      serviceTimesLines={['Domingos – Consultar horarios']}
      menuItems={[
        { text: 'Inicio', href: '/' },
        { text: 'Reuniones', href: '/reuniones' },
        { text: 'Escuela Bíblica', href: '/escuela-biblica' },
        { text: 'JUVE', href: '/juve' },
        { text: 'Exploradores', href: '/exploradores' },
        { text: 'Grupos', href: '/grupos' },
        { text: 'Radio FM', href: '/radio' },
        { text: 'Contacto', href: '/contacto' },

      ]}
      copyright="© 2026 Iglesia Vida Eterna · Todos los derechos reservados"
      poweredByText=""
      poweredByHref=""
    />
  </div>
</Layout>
