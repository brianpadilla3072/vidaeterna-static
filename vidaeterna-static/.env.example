# ──────────────────────────────────────────────────────────────────────────────
# Variables de entorno — copia este archivo como .env y completa los valores.
# Las variables con prefijo PUBLIC_ son accesibles en el cliente.
# ──────────────────────────────────────────────────────────────────────────────

# Hosted Button ID de PayPal para el botón de donaciones
# Encuéntralo en: PayPal > Herramientas > Botones de pago > Hosted Buttons
PUBLIC_PAYPAL_ID=your_paypal_hosted_button_id
